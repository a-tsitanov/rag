# API
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_LOG_LEVEL=info
API_KEYS=dev-local-key
API_CORS_ORIGINS=*
# Директория аплоадов. ВАЖНО: должна быть shared volume между api и worker
# (docker-compose: app_data:/app/data монтируется в оба сервиса).
API_UPLOAD_DIR=/app/data/uploads

# RabbitMQ (task broker + dashboard at :15672)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_TIMEOUT_S=10.0

# Taskiq — per-task knobs
TASKIQ_TASK_TIMEOUT_S=1800   # hard ceiling на process_document
TASKIQ_MAX_RETRIES=2         # SimpleRetryMiddleware default_retry_count
TASKIQ_PREFETCH=2            # QoS: сколько сообщений aio-pika забирает авансом

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_kb
MILVUS_TIMEOUT_S=10.0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_TIMEOUT_S=30.0

# PostgreSQL
POSTGRES_DB=enterprise_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONNECT_TIMEOUT_S=10

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=1024
OLLAMA_TIMEOUT_S=600.0

# LightRAG
LIGHTRAG_WORKING_DIR=/app/data/lightrag
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
# Empty → fall back to OLLAMA_MODEL / OLLAMA_EMBEDDING_MODEL / OLLAMA_EMBEDDING_DIM
LIGHTRAG_LLM_MODEL=
LIGHTRAG_EMBEDDING_MODEL=
LIGHTRAG_EMBEDDING_DIM=0
LIGHTRAG_MAX_TOKEN_SIZE=8192
# Per-call timeouts (seconds) — bump if local Ollama is slow
LIGHTRAG_LLM_TIMEOUT_S=600
LIGHTRAG_EMBEDDING_TIMEOUT_S=120
# Max concurrent LLM calls (1-2 for weak local CPUs, 4+ for GPU)
LIGHTRAG_MAX_ASYNC=2
# Ollama context window (num_ctx). Default 2048 is too small for
# LightRAG's entity-extraction prompts; keep >= 8192.
LIGHTRAG_NUM_CTX=16384

# Ingestion
INGESTION_BATCH_SIZE=10
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=50
